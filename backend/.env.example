# Render：新服务默认 Python 3.14，请在 Dashboard → Environment 设置 PYTHON_VERSION=3.11.11（勿写进 .env 文件，除非本地工具需要）
# 仓库根目录已有 .python-version，供 Render 识别

# MySQL:
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DB_NAME
# PostgreSQL：Render 常给 postgresql://...，代码会自动改为 postgresql+psycopg:// 以使用 psycopg3
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME
CORS_ORIGINS=https://your-frontend.vercel.app
DB_ECHO=false
HOST=0.0.0.0
PORT=8000
RELOAD=false
# Optional: 指向可执行 legacy BERT embedding 的 Python（需可 import tensorflow）
# BERT_V3_TF_PYTHON=/absolute/path/to/python
# Render 常见可用值（按实际环境调整）：
# BERT_V3_TF_PYTHON=/opt/render/project/src/.venv/bin/python
